===== JASS =====
function glass_i2b takes integer i returns boolean
    return i != 0
endfunction

function glass_Int_doubled takes integer self returns integer
    return (self + self)
endfunction
function glass_Int_is_positive takes integer self returns boolean
    return (self > 0)
endfunction

