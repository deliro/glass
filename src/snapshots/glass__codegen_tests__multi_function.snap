===== JASS =====
function glass_dispatch_void takes integer glass_closure returns integer
    return 0
endfunction

function glass_i2b takes integer i returns boolean
    return i != 0
endfunction

function glass_mul takes integer a, integer b returns integer
    return (a * b)
endfunction

function glass_add takes integer a, integer b returns integer
    return (a + b)
endfunction

function glass_combined takes integer x returns integer
    return glass_add(x, glass_mul(x, 2))
endfunction
