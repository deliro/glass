        call CreateItem(glass_Effect_CreateItem_item_type_id[fx_id], glass_Effect_CreateItem_x[fx_id], glass_Effect_CreateItem_y[fx_id])
    elseif fx_tag == glass_TAG_Effect_SetUnitMoveSpeed then
        call SetUnitMoveSpeed(glass_Effect_SetUnitMoveSpeed_unit[fx_id], glass_Effect_SetUnitMoveSpeed_speed[fx_id])
    elseif fx_tag == glass_TAG_Effect_CreateUnitCallback then
        set t = CreateTimer()
        set u = CreateUnit(Player(glass_Effect_CreateUnitCallback_owner[fx_id]), glass_Effect_CreateUnitCallback_type_id[fx_id], glass_Effect_CreateUnitCallback_x[fx_id], glass_Effect_CreateUnitCallback_y[fx_id], glass_Effect_CreateUnitCallback_facing[fx_id])
        call SaveInteger(glass_timer_ht, GetHandleId(t), 0, glass_Effect_CreateUnitCallback_callback[fx_id])
        call SaveUnitHandle(glass_timer_ht, GetHandleId(t), 1, u)
        call SaveInteger(glass_timer_ht, GetHandleId(t), 2, 1)
        call TimerStart(t, 0.0, false, function glass_timer_callback)
        set u = null
        set t = null
    endif
    call glass_Effect_dealloc(fx_id)
endfunction

function glass_process_effects takes integer effect_list returns nothing
    local integer current = effect_list
    loop
        exitwhen current == -1
        call glass_exec_effect(glass_List_integer_head[current])
        set current = glass_List_integer_tail[current]
    endloop
endfunction

function glass_send_msg takes integer tag, integer p0, integer p1 returns nothing
    local integer glass_result
    local integer glass_new_model
    local integer glass_effects
    set glass_msg_tag = tag
    set glass_msg_p0 = p0
    set glass_msg_p1 = p1
    set glass_result = glass_dispatch_update()
    set glass_new_model = glass_rt_tuple_0(glass_result)
    set glass_effects = glass_rt_tuple_1(glass_result)
    set glass_model = glass_new_model
    call glass_process_effects(glass_effects)
endfunction

function glass_runtime_init takes nothing returns nothing
    local integer glass_result
    local integer glass_effects
    set glass_timer_ht = InitHashtable()
    set glass_result = glass_init()
    set glass_model = glass_rt_tuple_0(glass_result)
    set glass_effects = glass_rt_tuple_1(glass_result)
    call glass_process_effects(glass_effects)
endfunction

function InitTrig_GlassInit takes nothing returns nothing
    local trigger t = CreateTrigger()
    call TriggerRegisterTimerEvent(t, 0.00, false)
    call TriggerAddAction(t, function glass_runtime_init)
endfunction
