    elseif fx_tag == glass_TAG_Effect_AddAbility then
        call UnitAddAbility(glass_Effect_AddAbility_unit[fx_id], glass_Effect_AddAbility_ability_id[fx_id])
    elseif fx_tag == glass_TAG_Effect_AddSfx then
        set sfx = AddSpecialEffect(glass_Effect_AddSfx_model[fx_id], glass_Effect_AddSfx_x[fx_id], glass_Effect_AddSfx_y[fx_id])
        call DestroyEffect(sfx)
        set sfx = null
    elseif fx_tag == glass_TAG_Effect_SetUnitHp then
        call SetUnitState(glass_Effect_SetUnitHp_unit[fx_id], UNIT_STATE_LIFE, glass_Effect_SetUnitHp_hp[fx_id])
