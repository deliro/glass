// ========== Glass Elm Runtime Functions ==========

function glass_rt_tuple_0 takes integer tid returns integer
    return glass_Tuple2_integer_integer_Tuple2_integer_integer__0[tid]
endfunction

function glass_rt_tuple_1 takes integer tid returns integer
    return glass_Tuple2_integer_integer_Tuple2_integer_integer__1[tid]
endfunction

function glass_dispatch_update takes nothing returns integer
    return glass_update(glass_model, glass_msg_tag)
endfunction

function glass_handle_register_unit takes unit u returns nothing
    call SaveUnitHandle(glass_handle_ht, GetHandleId(u), 0, u)
endfunction

function glass_handle_lookup_unit takes integer hid returns unit
    return LoadUnitHandle(glass_handle_ht, hid, 0)
endfunction

function glass_timer_callback takes nothing returns nothing
    local timer t = GetExpiredTimer()
    local integer hid = GetHandleId(t)
    local integer closure_id = LoadInteger(glass_timer_ht, hid, 0)
    local integer msg_result = 0
    local integer glass_result
    local integer glass_effects
    local integer current
    local integer fx_id
    local integer fx_tag
    local timer t2
    local unit u
    local effect sfx
    local texttag tt
    set msg_result = glass_dispatch_void(closure_id)
    call FlushChildHashtable(glass_timer_ht, hid)
    call DestroyTimer(t)
    set t = null
    set glass_msg_tag = msg_result
    set glass_msg_p0 = 0
    set glass_msg_p1 = 0
    set glass_result = glass_dispatch_update()
    set glass_model = glass_rt_tuple_0(glass_result)
    set glass_effects = glass_rt_tuple_1(glass_result)
    set current = glass_effects
    loop
        exitwhen current == -1
        set fx_id = glass_List_integer_head[current]
        set fx_tag = glass_Effect_tag[fx_id]
        if fx_tag == glass_TAG_After then
            set t2 = CreateTimer()
            call SaveInteger(glass_timer_ht, GetHandleId(t2), 0, glass_Effect_After_callback[fx_id])
            call TimerStart(t2, glass_Effect_After_duration[fx_id], false, function glass_timer_callback)
            set t2 = null
        elseif fx_tag == glass_TAG_DisplayText then
            call DisplayTimedTextToPlayer(Player(glass_Effect_DisplayText_player_id[fx_id]), 0, 0, glass_Effect_DisplayText_duration[fx_id], glass_Effect_DisplayText_text[fx_id])
        elseif fx_tag == glass_TAG_CreateUnit then
            set u = CreateUnit(Player(glass_Effect_CreateUnit_owner[fx_id]), glass_Effect_CreateUnit_type_id[fx_id], glass_Effect_CreateUnit_x[fx_id], glass_Effect_CreateUnit_y[fx_id], glass_Effect_CreateUnit_facing[fx_id])
            call glass_handle_register_unit(u)
            set u = null
        elseif fx_tag == glass_TAG_DamageUnit then
            call UnitDamageTarget(glass_handle_lookup_unit(glass_Effect_DamageUnit_source_id[fx_id]), glass_handle_lookup_unit(glass_Effect_DamageUnit_target_id[fx_id]), glass_Effect_DamageUnit_amount[fx_id], true, false, glass_Effect_DamageUnit_attack_type[fx_id], glass_Effect_DamageUnit_damage_type[fx_id], 0)
        elseif fx_tag == glass_TAG_AddSfx then
            set sfx = AddSpecialEffect(glass_Effect_AddSfx_model[fx_id], glass_Effect_AddSfx_x[fx_id], glass_Effect_AddSfx_y[fx_id])
            call DestroyEffect(sfx)
            set sfx = null
        endif
        call glass_Effect_dealloc(fx_id)
        set current = glass_List_integer_tail[current]
    endloop
endfunction

function glass_exec_effect takes integer fx_id returns nothing
    local integer fx_tag = glass_Effect_tag[fx_id]
    local timer t
    local unit u
    local effect sfx
    local texttag tt
    if fx_tag == glass_TAG_After then
        set t = CreateTimer()
        call SaveInteger(glass_timer_ht, GetHandleId(t), 0, glass_Effect_After_callback[fx_id])
        call TimerStart(t, glass_Effect_After_duration[fx_id], false, function glass_timer_callback)
        set t = null
    elseif fx_tag == glass_TAG_DisplayText then
        call DisplayTimedTextToPlayer(Player(glass_Effect_DisplayText_player_id[fx_id]), 0, 0, glass_Effect_DisplayText_duration[fx_id], glass_Effect_DisplayText_text[fx_id])
    elseif fx_tag == glass_TAG_DamageUnit then
        call UnitDamageTarget(glass_handle_lookup_unit(glass_Effect_DamageUnit_source_id[fx_id]), glass_handle_lookup_unit(glass_Effect_DamageUnit_target_id[fx_id]), glass_Effect_DamageUnit_amount[fx_id], true, false, glass_Effect_DamageUnit_attack_type[fx_id], glass_Effect_DamageUnit_damage_type[fx_id], 0)
    elseif fx_tag == glass_TAG_CreateUnit then
        set u = CreateUnit(Player(glass_Effect_CreateUnit_owner[fx_id]), glass_Effect_CreateUnit_type_id[fx_id], glass_Effect_CreateUnit_x[fx_id], glass_Effect_CreateUnit_y[fx_id], glass_Effect_CreateUnit_facing[fx_id])
        call glass_handle_register_unit(u)
        set u = null
    elseif fx_tag == glass_TAG_RemoveUnit then
        call RemoveUnit(glass_handle_lookup_unit(glass_Effect_RemoveUnit_unit_id[fx_id]))
    elseif fx_tag == glass_TAG_MoveUnit then
        call SetUnitPosition(glass_handle_lookup_unit(glass_Effect_MoveUnit_unit_id[fx_id]), glass_Effect_MoveUnit_x[fx_id], glass_Effect_MoveUnit_y[fx_id])
    elseif fx_tag == glass_TAG_PlayAnimation then
        call SetUnitAnimation(glass_handle_lookup_unit(glass_Effect_PlayAnimation_unit_id[fx_id]), glass_Effect_PlayAnimation_anim[fx_id])
    elseif fx_tag == glass_TAG_AddAbility then
        call UnitAddAbility(glass_handle_lookup_unit(glass_Effect_AddAbility_unit_id[fx_id]), glass_Effect_AddAbility_ability_id[fx_id])
    elseif fx_tag == glass_TAG_AddSfx then
        set sfx = AddSpecialEffect(glass_Effect_AddSfx_model[fx_id], glass_Effect_AddSfx_x[fx_id], glass_Effect_AddSfx_y[fx_id])
        call DestroyEffect(sfx)
        set sfx = null
    elseif fx_tag == glass_TAG_SetUnitHp then
        call SetUnitState(glass_handle_lookup_unit(glass_Effect_SetUnitHp_unit_id[fx_id]), UNIT_STATE_LIFE, glass_Effect_SetUnitHp_hp[fx_id])
    elseif fx_tag == glass_TAG_SetUnitMana then
        call SetUnitState(glass_handle_lookup_unit(glass_Effect_SetUnitMana_unit_id[fx_id]), UNIT_STATE_MANA, glass_Effect_SetUnitMana_mana[fx_id])
    elseif fx_tag == glass_TAG_PanCamera then
        if GetLocalPlayer() == Player(glass_Effect_PanCamera_player_id[fx_id]) then
            call PanCameraTo(glass_Effect_PanCamera_x[fx_id], glass_Effect_PanCamera_y[fx_id])
        endif
    elseif fx_tag == glass_TAG_ShowFloatingText then
        set tt = CreateTextTag()
        call SetTextTagText(tt, glass_Effect_ShowFloatingText_text[fx_id], glass_Effect_ShowFloatingText_size[fx_id])
        call SetTextTagPos(tt, glass_Effect_ShowFloatingText_x[fx_id], glass_Effect_ShowFloatingText_y[fx_id], 0.0)
        call SetTextTagLifespan(tt, 3.0)
        call SetTextTagPermanent(tt, false)
        call SetTextTagVelocity(tt, 0.0, 0.04)
        set tt = null
    endif
    call glass_Effect_dealloc(fx_id)
endfunction

function glass_process_effects takes integer effect_list returns nothing
    local integer current = effect_list
    loop
        exitwhen current == -1
        call glass_exec_effect(glass_List_integer_head[current])
        set current = glass_List_integer_tail[current]
    endloop
endfunction

function glass_send_msg takes integer tag, integer p0, integer p1 returns nothing
    local integer glass_result
    local integer glass_new_model
    local integer glass_effects
    set glass_msg_tag = tag
    set glass_msg_p0 = p0
    set glass_msg_p1 = p1
    set glass_result = glass_dispatch_update()
    set glass_new_model = glass_rt_tuple_0(glass_result)
    set glass_effects = glass_rt_tuple_1(glass_result)
    set glass_model = glass_new_model
    call glass_process_effects(glass_effects)
endfunction

function glass_runtime_init takes nothing returns nothing
    local integer glass_result
    local integer glass_effects
    set glass_timer_ht = InitHashtable()
    set glass_handle_ht = InitHashtable()
    set glass_result = glass_init()
    set glass_model = glass_rt_tuple_0(glass_result)
    set glass_effects = glass_rt_tuple_1(glass_result)
    call glass_process_effects(glass_effects)
endfunction

function InitTrig_GlassInit takes nothing returns nothing
    local trigger t = CreateTrigger()
    call TriggerRegisterTimerEvent(t, 0.00, false)
    call TriggerAddAction(t, function glass_runtime_init)
endfunction
