    elseif fx_tag == glass_TAG_Effect_KillUnit then
        call KillUnit(glass_Effect_KillUnit_unit[fx_id])
    elseif fx_tag == glass_TAG_Effect_RemoveAbility then
        call UnitRemoveAbility(glass_Effect_RemoveAbility_unit[fx_id], glass_Effect_RemoveAbility_ability_id[fx_id])
    elseif fx_tag == glass_TAG_Effect_SetUnitOwner then
        call SetUnitOwner(glass_Effect_SetUnitOwner_unit[fx_id], Player(glass_Effect_SetUnitOwner_player_id[fx_id]), true)
