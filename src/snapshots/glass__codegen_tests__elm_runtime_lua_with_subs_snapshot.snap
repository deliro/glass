        end)
        glass_active_subs[key] = { handle = t, kind = "trigger" }
    elseif sub.tag == glass_TAG_Subscription_OnConstructionStart then
        local t = CreateTrigger()
        for i = 0, bj_MAX_PLAYER_SLOTS - 1 do
            TriggerRegisterPlayerUnitEvent(t, Player(i), EVENT_PLAYER_UNIT_CONSTRUCT_START, nil)
        end
        TriggerAddAction(t, function()
