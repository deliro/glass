        end
        TriggerAddAction(t, function()
            glass_send_msg(handler(GetPlayerId(GetTriggerPlayer())))
        end)
        glass_active_subs[key] = { handle = t, kind = "trigger" }
    elseif sub.tag == glass_TAG_Subscription_OnHeroLevelUp then
        local t = CreateTrigger()
        for i = 0, bj_MAX_PLAYER_SLOTS - 1 do
            TriggerRegisterPlayerUnitEvent(t, Player(i), EVENT_PLAYER_HERO_LEVEL, nil)
        end
        TriggerAddAction(t, function()
            glass_send_msg(handler(GetTriggerUnit()))
        end)
        glass_active_subs[key] = { handle = t, kind = "trigger" }
    elseif sub.tag == glass_TAG_Subscription_OnConstructionFinish then
        local t = CreateTrigger()
        for i = 0, bj_MAX_PLAYER_SLOTS - 1 do
            TriggerRegisterPlayerUnitEvent(t, Player(i), EVENT_PLAYER_UNIT_CONSTRUCT_FINISH, nil)
        end
        TriggerAddAction(t, function()
            glass_send_msg(handler(GetTriggerUnit()))
        end)
        glass_active_subs[key] = { handle = t, kind = "trigger" }
    elseif sub.tag == glass_TAG_Subscription_OnSpellGround then
        local t = CreateTrigger()
        for i = 0, bj_MAX_PLAYER_SLOTS - 1 do
            TriggerRegisterPlayerUnitEvent(t, Player(i), EVENT_PLAYER_UNIT_SPELL_EFFECT, nil)
        end
        TriggerAddAction(t, function()
            glass_send_msg(handler(GetTriggerUnit(), GetSpellAbilityId(), GetSpellTargetX(), GetSpellTargetY()))
        end)
        glass_active_subs[key] = { handle = t, kind = "trigger" }
    elseif sub.tag == glass_TAG_Subscription_OnSummon then
        local t = CreateTrigger()
        for i = 0, bj_MAX_PLAYER_SLOTS - 1 do
            TriggerRegisterPlayerUnitEvent(t, Player(i), EVENT_PLAYER_UNIT_SUMMON, nil)
        end
        TriggerAddAction(t, function()
