        end)
        glass_active_subs[key] = { handle = t, kind = "trigger" }
    elseif sub.tag == glass_TAG_Subscription_OnUnitSold then
        local t = CreateTrigger()
        for i = 0, bj_MAX_PLAYER_SLOTS - 1 do
            TriggerRegisterPlayerUnitEvent(t, Player(i), EVENT_PLAYER_UNIT_SELL, nil)
        end
        TriggerAddAction(t, function()
            glass_send_msg(handler(GetTriggerUnit(), GetSoldUnit()))
        end)
        glass_active_subs[key] = { handle = t, kind = "trigger" }
    elseif sub.tag == glass_TAG_Subscription_OnItemSold then
        local t = CreateTrigger()
        for i = 0, bj_MAX_PLAYER_SLOTS - 1 do
            TriggerRegisterPlayerUnitEvent(t, Player(i), EVENT_PLAYER_UNIT_SELL_ITEM, nil)
        end
        TriggerAddAction(t, function()
            glass_send_msg(handler(GetTriggerUnit(), GetItemTypeId(GetSoldItem())))
        end)
        glass_active_subs[key] = { handle = t, kind = "trigger" }
    elseif sub.tag == glass_TAG_Subscription_OnUnitTrained then
        local t = CreateTrigger()
        for i = 0, bj_MAX_PLAYER_SLOTS - 1 do
            TriggerRegisterPlayerUnitEvent(t, Player(i), EVENT_PLAYER_UNIT_TRAIN_FINISH, nil)
        end
        TriggerAddAction(t, function()
            glass_send_msg(handler(GetTriggerUnit(), GetTrainedUnit()))
        end)
        glass_active_subs[key] = { handle = t, kind = "trigger" }
    elseif sub.tag == glass_TAG_Subscription_OnResearchFinish then
        local t = CreateTrigger()
        for i = 0, bj_MAX_PLAYER_SLOTS - 1 do
            TriggerRegisterPlayerUnitEvent(t, Player(i), EVENT_PLAYER_UNIT_RESEARCH_FINISH, nil)
        end
        TriggerAddAction(t, function()
            glass_send_msg(handler(GetTriggerUnit(), GetResearched()))
        end)
        glass_active_subs[key] = { handle = t, kind = "trigger" }
    elseif sub.tag == glass_TAG_Subscription_OnConstructionStart then
        local t = CreateTrigger()
        for i = 0, bj_MAX_PLAYER_SLOTS - 1 do
            TriggerRegisterPlayerUnitEvent(t, Player(i), EVENT_PLAYER_UNIT_CONSTRUCT_START, nil)
        end
        TriggerAddAction(t, function()
            glass_send_msg(handler(GetTriggerUnit()))
        end)
        glass_active_subs[key] = { handle = t, kind = "trigger" }
    elseif sub.tag == glass_TAG_Subscription_OnSpellFinish then
        local t = CreateTrigger()
        for i = 0, bj_MAX_PLAYER_SLOTS - 1 do
            TriggerRegisterPlayerUnitEvent(t, Player(i), EVENT_PLAYER_UNIT_SPELL_FINISH, nil)
        end
        TriggerAddAction(t, function()
            glass_send_msg(handler(GetTriggerUnit(), GetSpellAbilityId()))
        end)
        glass_active_subs[key] = { handle = t, kind = "trigger" }
    elseif sub.tag == glass_TAG_Subscription_OnOrderIssued then
        local t = CreateTrigger()
        for i = 0, bj_MAX_PLAYER_SLOTS - 1 do
