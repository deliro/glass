function glass_unregister_one_sub(key)
    local entry = glass_active_subs[key]
    if entry ~= nil then
        if entry.kind == "timer" then
            PauseTimer(entry.handle)
            DestroyTimer(entry.handle)
        else
            DisableTrigger(entry.handle)
            DestroyTrigger(entry.handle)
        end
        glass_active_subs[key] = nil
    end
end

function glass_reconcile_subs(new_subs)
    local new_keys = {}
    local current = new_subs
    local idx = 0
    while current ~= nil do
        local sub = current.head
        local key = tostring(sub.tag) .. "_" .. tostring(idx)
        new_keys[key] = sub
        idx = idx + 1
        current = current.tail
    end
    for key, _ in pairs(glass_active_subs) do
        if new_keys[key] == nil then
            glass_unregister_one_sub(key)
        end
    end
    for key, sub in pairs(new_keys) do
        if glass_active_subs[key] == nil then
            glass_register_one_sub(sub, key)
        end
    end
end

function glass_runtime_init()
    glass_timer_ht = InitHashtable()
    local result = glass_init()
    glass_model = result[1]
    glass_process_effects(result[2])
    glass_reconcile_subs(glass_subscriptions(glass_model))
end

do
    local t = CreateTrigger()
    TriggerRegisterTimerEvent(t, 0.00, false)
    TriggerAddAction(t, glass_runtime_init)
end
