function glass_sub_timer_cb takes nothing returns nothing
    local timer t = GetExpiredTimer()
    local integer closure_id = LoadInteger(glass_timer_ht, GetHandleId(t), 0)
    call glass_send_msg(glass_dispatch_void(closure_id), 0, 0)
    set t = null
endfunction

function glass_register_one_sub takes integer sub_id, integer idx returns nothing
    local integer sub_tag = glass_Subscription_tag[sub_id]
    local trigger t = null
    local timer tm = null
    local integer i = 0
    if sub_tag == glass_TAG_Subscription_OnAttack then
        set t = CreateTrigger()
        set i = 0
        loop
            exitwhen i >= bj_MAX_PLAYER_SLOTS
            call TriggerRegisterPlayerUnitEvent(t, Player(i), EVENT_PLAYER_UNIT_ATTACKED, null)
            set i = i + 1
        endloop
        call SaveInteger(glass_timer_ht, GetHandleId(t), 0, glass_Subscription_OnAttack_handler[sub_id])
        call TriggerAddAction(t, function glass_sub_cb_OnAttack)
        set glass_sub_triggers[idx] = t
        set t = null
    elseif sub_tag == glass_TAG_Subscription_OnDeath then
        set t = CreateTrigger()
        set i = 0
        loop
            exitwhen i >= bj_MAX_PLAYER_SLOTS
            call TriggerRegisterPlayerUnitEvent(t, Player(i), EVENT_PLAYER_UNIT_DEATH, null)
            set i = i + 1
        endloop
        call SaveInteger(glass_timer_ht, GetHandleId(t), 0, glass_Subscription_OnDeath_handler[sub_id])
        call TriggerAddAction(t, function glass_sub_cb_OnDeath)
        set glass_sub_triggers[idx] = t
        set t = null
    elseif sub_tag == glass_TAG_Subscription_OnTimer then
        set tm = CreateTimer()
        call SaveInteger(glass_timer_ht, GetHandleId(tm), 0, glass_Subscription_OnTimer_handler[sub_id])
        call TimerStart(tm, glass_Subscription_OnTimer_interval[sub_id], true, function glass_sub_timer_cb)
        set glass_sub_timers[idx] = tm
        set tm = null
    elseif sub_tag == glass_TAG_Subscription_OnSpellEffect then
        set t = CreateTrigger()
        set i = 0
        loop
            exitwhen i >= bj_MAX_PLAYER_SLOTS
            call TriggerRegisterPlayerUnitEvent(t, Player(i), EVENT_PLAYER_UNIT_SPELL_EFFECT, null)
            set i = i + 1
        endloop
        call SaveInteger(glass_timer_ht, GetHandleId(t), 0, glass_Subscription_OnSpellEffect_handler[sub_id])
        call TriggerAddAction(t, function glass_sub_cb_OnSpellEffect)
        set glass_sub_triggers[idx] = t
        set t = null
    elseif sub_tag == glass_TAG_Subscription_OnItemPickup then
        set t = CreateTrigger()
        set i = 0
