function glass_process_effects takes integer effect_list returns nothing
    local integer current = effect_list
    loop
        exitwhen current == -1
        call glass_exec_effect(glass_List_integer_head[current])
        set current = glass_List_integer_tail[current]
    endloop
endfunction

function glass_send_msg takes integer tag, integer p0, integer p1 returns nothing
    local integer glass_result
    local integer glass_new_model
    local integer glass_effects
    set glass_msg_tag = tag
    set glass_msg_p0 = p0
    set glass_msg_p1 = p1
    set glass_result = glass_dispatch_update()
    set glass_new_model = glass_rt_tuple_0(glass_result)
    set glass_effects = glass_rt_tuple_1(glass_result)
    set glass_model = glass_new_model
    call glass_process_effects(glass_effects)
    call glass_reconcile_subs()
endfunction

function glass_sub_cb_OnAttack takes nothing returns nothing
    local integer closure_id = LoadInteger(glass_timer_ht, GetHandleId(GetTriggeringTrigger()), 0)
    call glass_send_msg(glass_dispatch_2_unit_unit(closure_id, GetAttacker(), GetTriggerUnit()), 0, 0)
endfunction

function glass_sub_cb_OnDeath takes nothing returns nothing
    local integer closure_id = LoadInteger(glass_timer_ht, GetHandleId(GetTriggeringTrigger()), 0)
