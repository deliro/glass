    set glass_sub_tags[idx] = sub_tag
endfunction

function glass_unregister_one_sub takes integer idx returns nothing
    if glass_sub_timers[idx] != null then
        call PauseTimer(glass_sub_timers[idx])
        call FlushChildHashtable(glass_timer_ht, GetHandleId(glass_sub_timers[idx]))
        call DestroyTimer(glass_sub_timers[idx])
        set glass_sub_timers[idx] = null
    endif
    if glass_sub_triggers[idx] != null then
        call DisableTrigger(glass_sub_triggers[idx])
        call FlushChildHashtable(glass_timer_ht, GetHandleId(glass_sub_triggers[idx]))
        call DestroyTrigger(glass_sub_triggers[idx])
        set glass_sub_triggers[idx] = null
    endif
    set glass_sub_tags[idx] = 0
endfunction

function glass_reconcile_subs takes nothing returns nothing
    local integer new_list = glass_subscriptions(glass_model)
    local integer current = new_list
    local integer new_count = 0
    local integer idx = 0
    local integer new_tag = 0
    local integer new_sub_id = 0
    loop
        exitwhen current == -1
        set new_count = new_count + 1
        set current = glass_List_integer_tail[current]
    endloop
    set idx = new_count
    loop
        exitwhen idx >= glass_sub_count
        call glass_unregister_one_sub(idx)
        set idx = idx + 1
    endloop
    set current = new_list
    set idx = 0
    loop
        exitwhen current == -1
        set new_sub_id = glass_List_integer_head[current]
        set new_tag = glass_Subscription_tag[new_sub_id]
        if idx >= glass_sub_count then
            call glass_register_one_sub(new_sub_id, idx)
        elseif glass_sub_tags[idx] != new_tag then
            call glass_unregister_one_sub(idx)
            call glass_register_one_sub(new_sub_id, idx)
        endif
        set idx = idx + 1
        set current = glass_List_integer_tail[current]
    endloop
    set glass_sub_count = new_count
endfunction

function glass_runtime_init takes nothing returns nothing
    local integer glass_result
    local integer glass_effects
    set glass_timer_ht = InitHashtable()
    set glass_result = glass_init()
    set glass_model = glass_rt_tuple_0(glass_result)
    set glass_effects = glass_rt_tuple_1(glass_result)
    call glass_process_effects(glass_effects)
    call glass_reconcile_subs()
endfunction

function InitTrig_GlassInit takes nothing returns nothing
    local trigger t = CreateTrigger()
    call TriggerRegisterTimerEvent(t, 0.00, false)
    call TriggerAddAction(t, function glass_runtime_init)
endfunction
