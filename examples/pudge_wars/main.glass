const HOOK_ABILITY: Int = 'A000'
const GRAPPLE_ABILITY: Int = 'A00C'
const TOSS_ABILITY: Int = 'A019'
const FISSURE_ABILITY: Int = 'A001'
const BARRICADE_ABILITY: Int = 'A00H'
const DETONATE_ABILITY: Int = 'A00U'
const RESPAWN_TICK_INTERVAL: Float = 1.0
const INVULN_DURATION: Float = 3.0
const HERO_TYPE_ID: Int = 'H000'
const UPGRADE_SPEED: Int = 'A00Z'
const UPGRADE_DAMAGE: Int = 'A00X'
const UPGRADE_RANGE: Int = 'A00W'
const UPGRADE_RADIUS: Int = 'A00Y'
const DETONATE_SELF_DAMAGE: Float = 100000.0
const DETONATE_AOE_DAMAGE: Float = 15000.0
const DETONATE_RADIUS: Float = 300.0
const THUNDER_AOE_RADIUS: Float = 250.0
const THUNDER_AOE_DAMAGE: Float = 150.0
const FLAME_TRAIL_UNIT_ID: Int = 'hFLM'
const FLAME_TIMED_LIFE_BUFF: Int = 'BTLF'
const FLAME_TIMED_LIFE_DURATION: Float = 7.5
const CENTER_DEFLECTOR_ID: Int = 'n006'
const NEUTRAL_PLAYER: Int = 15
const ALLIANCE_PASSIVE: Int = 0
const ALLIANCE_HELP_REQUEST: Int = 1
const ALLIANCE_HELP_RESPONSE: Int = 2
const ALLIANCE_SHARED_XP: Int = 3
const ALLIANCE_SHARED_SPELLS: Int = 4
const ALLIANCE_SHARED_VISION: Int = 5

pub enum Msg {
    SpellCast { caster: Unit, spell_id: Int, target: Unit }
    SpellGround { caster: Unit, spell_id: Int, x: Float, y: Float }
    HookTick
    HookTipCreated { hook_index: Int, tip: Unit }
    ChainLinkCreated { hook_index: Int, link: Unit }
    UnitDied { victim: Unit, killer: Unit }
    ChatCommand { player_id: Int, text: String }
    PlayerLeft { player_id: Int }
    HeroLevelUp { leveled: Unit }
    DamageTaken { source: Unit, target: Unit, amount: Float }
    RespawnTick
    RemoveInvuln { invuln_player: Int }
    HeroCreated { player_index: Int, created_hero: Unit }
    TimedModeExpired
    PowerupSpawnTick
    PowerupTick
    PowerupCreated { kind: types.PowerupKind, direction: Float, created_unit: Unit }
    BuffTick
    ItemPickedUp { buyer: Unit, item_type: Int }
    MineCreated { owner_index: Int, x: Float, y: Float, close_dmg: Float, far_dmg: Float, created_unit: Unit }
    BarricadeCreated { owner_index: Int, hp: Float, created_unit: Unit }
    BladeCreated { barrier_index: Int, blade_index: Int, created_blade: Unit }
}

pub struct Model {
    phase: types.Phase,
    mode: types.GameMode,
    modifiers: types.Modifiers,
    players: List(types.PlayerData),
    hooks: List(types.HookData),
    tick_count: Int,
    powerups: List(types.Powerup),
    next_spawn_south: Bool,
    spawn_count: Int,
    active_mines: List(types.ActiveMine),
    barricades: List(types.Barricade),
    blade_barriers: List(types.BladeBarrierState),
    dynamites: List(types.DynamiteState),
}

fn make_west_players(i: Int) -> List(types.PlayerData) {
    case i > 4 {
        True -> []
        False -> [types.new_player(i, Team::West) | make_west_players(i + 1)]
    }
}

fn make_east_players(i: Int) -> List(types.PlayerData) {
    case i > 10 {
        True -> []
        False -> [types.new_player(i, Team::East) | make_east_players(i + 1)]
    }
}

fn append_players(xs: List(types.PlayerData), ys: List(types.PlayerData)) -> List(types.PlayerData) {
    case xs {
        [] -> ys
        [h | t] -> [h | append_players(t, ys)]
    }
}

fn append_effects(xs: List(effect.Effect(Msg)), ys: List(effect.Effect(Msg))) -> List(effect.Effect(Msg)) {
    case xs {
        [] -> ys
        [h | t] -> [h | append_effects(t, ys)]
    }
}

fn get_spawn_for_team(team: types.Team) -> (Float, Float) {
    case team {
        West -> (arena.west_spawn_x(), arena.west_spawn_y())
        East -> (arena.east_spawn_x(), arena.east_spawn_y())
    }
}

fn make_hero_effects(players: List(types.PlayerData)) -> List(effect.Effect(Msg)) {
    case players {
        [] -> []
        [p | rest] -> {
            let (sx, sy) = get_spawn_for_team(p.team)
            let pid = p.index
            let eff = effect.create_unit_callback(
                pid,
                HERO_TYPE_ID,
                sx,
                sy,
                0.0,
                fn(u: Unit) -> Msg { Msg::HeroCreated { player_index: pid, created_hero: u } }
            )
            [eff | make_hero_effects(rest)]
        }
    }
}

fn rebuild_player(p: types.PlayerData, new_hero: Option(Unit)) -> types.PlayerData {
    types.PlayerData {
        index: p.index, team: p.team, alive: p.alive,
        kills: p.kills, deaths: p.deaths, spree: p.spree,
        hook_speed: p.hook_speed, hook_damage: p.hook_damage,
        hook_range: p.hook_range, hook_radius: p.hook_radius,
        respawn_timer: p.respawn_timer, gold: p.gold,
        hero: new_hero, left: p.left,
        speed_level: p.speed_level, damage_level: p.damage_level,
        range_level: p.range_level, radius_level: p.radius_level,
        items: p.items, buffs: p.buffs,
        move_speed_bonus: p.move_speed_bonus,
    }
}

fn set_player_hero(players: List(types.PlayerData), pid: Int, new_hero: Unit) -> List(types.PlayerData) {
    case players {
        [] -> []
        [p | rest] -> case p.index == pid {
            True -> [rebuild_player(p, Option::Some(new_hero)) | rest]
            False -> [p | set_player_hero(rest, pid, new_hero)]
        }
    }
}

fn get_player_hook_speed(players: List(types.PlayerData), pid: Int) -> Float {
    case players {
        [] -> 1600.0
        [p | rest] -> case p.index == pid {
            True -> p.hook_speed
            False -> get_player_hook_speed(rest, pid)
        }
    }
}

fn get_player_hook_range(players: List(types.PlayerData), pid: Int) -> Float {
    case players {
        [] -> 1300.0
        [p | rest] -> case p.index == pid {
            True -> p.hook_range
            False -> get_player_hook_range(rest, pid)
        }
    }
}

fn get_player_hook_damage(players: List(types.PlayerData), pid: Int) -> Float {
    case players {
        [] -> 360.0
        [p | rest] -> case p.index == pid {
            True -> p.hook_damage
            False -> get_player_hook_damage(rest, pid)
        }
    }
}

fn get_player_hook_radius(players: List(types.PlayerData), pid: Int) -> Float {
    case players {
        [] -> 150.0
        [p | rest] -> case p.index == pid {
            True -> p.hook_radius
            False -> get_player_hook_radius(rest, pid)
        }
    }
}

fn get_player_team(players: List(types.PlayerData), pid: Int) -> types.Team {
    case players {
        [] -> Team::West
        [p | rest] -> case p.index == pid {
            True -> p.team
            False -> get_player_team(rest, pid)
        }
    }
}

fn get_player_hero(players: List(types.PlayerData), pid: Int) -> Option(Unit) {
    case players {
        [] -> Option::None
        [p | rest] -> case p.index == pid {
            True -> p.hero
            False -> get_player_hero(rest, pid)
        }
    }
}

fn get_player_items(players: List(types.PlayerData), pid: Int) -> List(types.OwnedItem) {
    case players {
        [] -> []
        [p | rest] -> case p.index == pid {
            True -> p.items
            False -> get_player_items(rest, pid)
        }
    }
}

fn get_player_buffs(players: List(types.PlayerData), pid: Int) -> List(types.ActiveBuff) {
    case players {
        [] -> []
        [p | rest] -> case p.index == pid {
            True -> p.buffs
            False -> get_player_buffs(rest, pid)
        }
    }
}

fn get_player_stats_text(players: List(types.PlayerData), pid: Int) -> String {
    case players {
        [] -> "No stats available."
        [p | rest] -> case p.index == pid {
            True ->
                "Range: " <> int.to_string(float.to_int(p.hook_range))
                <> " | Damage: " <> int.to_string(float.to_int(p.hook_damage))
                <> " | Radius: " <> int.to_string(float.to_int(p.hook_radius))
                <> " | Speed: " <> int.to_string(float.to_int(p.hook_speed))
            False -> get_player_stats_text(rest, pid)
        }
    }
}

fn launch_hook(model: Model, caster: Unit, tx: Float, ty: Float, variant: types.HookVariant) -> (Model, List(effect.Effect(Msg))) {
    let owner_id = player.get_id(player.get_owner(clone(caster)))
    let speed = get_player_hook_speed(model.players, owner_id)
    let range = get_player_hook_range(model.players, owner_id)
    let base_damage = get_player_hook_damage(model.players, owner_id)
    let radius = get_player_hook_radius(model.players, owner_id)
    let player_buffs = get_player_buffs(model.players, owner_id)
    let player_items = get_player_items(model.players, owner_id)
    let has_thunder = powerup.has_buff(player_buffs, PowerupKind::Thunder)
    let has_flame = powerup.has_buff(player_buffs, PowerupKind::Flame)
    let spectral = powerup.has_buff(player_buffs, PowerupKind::SpectralDagger)
    let barathrum_lvl = items.item_level(player_items, ItemKind::BarathrumLantern)
    let damage = case barathrum_lvl > 0 {
        True -> base_damage + items.barathrum_speed_bonus(speed, barathrum_lvl)
        False -> base_damage
    }
    let hook_idx = list_length_hooks(model.hooks)
    let result = hook.launch(caster, owner_id, tx, ty, speed, range, damage, radius, variant, has_thunder, has_flame, spectral)
    let new_hooks = append_hooks(model.hooks, [result.hook])
    let new_model = Model {
        phase: model.phase,
        mode: model.mode,
        modifiers: model.modifiers,
        players: model.players,
        hooks: new_hooks,
        tick_count: model.tick_count,
        powerups: model.powerups,
        next_spawn_south: model.next_spawn_south,
        spawn_count: model.spawn_count,
        active_mines: model.active_mines, barricades: model.barricades,
        blade_barriers: model.blade_barriers, dynamites: model.dynamites,
    }
    let tip_effect = effect.create_unit_callback(
        owner_id,
        hook.tip_type_id(),
        tx,
        ty,
        0.0,
        fn(u: Unit) -> Msg { Msg::HookTipCreated { hook_index: hook_idx, tip: u } }
    )
    (new_model, [tip_effect])
}

fn handle_spell_ground(model: Model, caster: Unit, spell_id: Int, tx: Float, ty: Float) -> (Model, List(effect.Effect(Msg))) {
    case spell_id {
        HOOK_ABILITY -> launch_hook(model, caster, tx, ty, HookVariant::Normal)
        GRAPPLE_ABILITY -> launch_hook(model, caster, tx, ty, HookVariant::Grapple)
        TOSS_ABILITY -> launch_hook(model, caster, tx, ty, HookVariant::Toss)
        FISSURE_ABILITY -> handle_fissure(model, caster, tx, ty)
        BARRICADE_ABILITY -> handle_barricade(model, caster, tx, ty)
        _ -> handle_upgrade(model, caster, spell_id)
    }
}

fn handle_spell_cast(model: Model, caster: Unit, spell_id: Int) -> (Model, List(effect.Effect(Msg))) {
    case spell_id {
        DETONATE_ABILITY -> {
            let cx = unit.get_x(clone(caster))
            let cy = unit.get_y(clone(caster))
            let self_dmg = effect.damage_unit(clone(caster), clone(caster), DETONATE_SELF_DAMAGE, 5, 4)
            let aoe = effect.for_units_in_range(cx, cy, DETONATE_RADIUS, fn(u: Unit) -> Msg {
                Msg::DamageTaken { source: clone(caster), target: u, amount: DETONATE_AOE_DAMAGE }
            })
            let sfx = effect.add_sfx("Abilities\\Spells\\Human\\MarkOfChaos\\MarkOfChaosTarget.mdl", cx, cy)
            (model, [self_dmg, aoe, sfx])
        }
        _ -> handle_upgrade(model, caster, spell_id)
    }
}

fn rebuild_model(model: Model, players: List(types.PlayerData)) -> Model {
    Model {
        phase: model.phase, mode: model.mode, modifiers: model.modifiers,
        players: players, hooks: model.hooks, tick_count: model.tick_count,
        powerups: model.powerups, next_spawn_south: model.next_spawn_south,
        spawn_count: model.spawn_count,
        active_mines: model.active_mines, barricades: model.barricades,
        blade_barriers: model.blade_barriers, dynamites: model.dynamites,
    }
}

fn rebuild_model_hooks(model: Model, hooks: List(types.HookData)) -> Model {
    Model {
        phase: model.phase, mode: model.mode, modifiers: model.modifiers,
        players: model.players, hooks: hooks, tick_count: model.tick_count,
        powerups: model.powerups, next_spawn_south: model.next_spawn_south,
        spawn_count: model.spawn_count,
        active_mines: model.active_mines, barricades: model.barricades,
        blade_barriers: model.blade_barriers, dynamites: model.dynamites,
    }
}

fn handle_upgrade(model: Model, caster: Unit, spell_id: Int) -> (Model, List(effect.Effect(Msg))) {
    let owner_id = player.get_id(player.get_owner(clone(caster)))
    case spell_id {
        UPGRADE_SPEED -> {
            let new_players = upgrade_player_speed(model.players, owner_id)
            (rebuild_model(model, new_players), [])
        }
        UPGRADE_DAMAGE -> {
            let new_players = upgrade_player_damage(model.players, owner_id)
            (rebuild_model(model, new_players), [])
        }
        UPGRADE_RANGE -> {
            let new_players = upgrade_player_range(model.players, owner_id)
            (rebuild_model(model, new_players), [])
        }
        UPGRADE_RADIUS -> {
            let new_players = upgrade_player_radius(model.players, owner_id)
            (rebuild_model(model, new_players), [])
        }
        _ -> (model, [])
    }
}

fn upgrade_player_speed(players: List(types.PlayerData), pid: Int) -> List(types.PlayerData) {
    case players {
        [] -> []
        [p | rest] -> case p.index == pid {
            True -> case p.speed_level < 25 {
                True -> [types.PlayerData {
                    index: p.index, team: p.team, alive: p.alive,
                    kills: p.kills, deaths: p.deaths, spree: p.spree,
                    hook_speed: p.hook_speed + 20.0, hook_damage: p.hook_damage,
                    hook_range: p.hook_range, hook_radius: p.hook_radius,
                    respawn_timer: p.respawn_timer, gold: p.gold,
                    hero: p.hero, left: p.left,
                    speed_level: p.speed_level + 1, damage_level: p.damage_level,
                    range_level: p.range_level, radius_level: p.radius_level,
                    items: p.items, buffs: p.buffs,
                    move_speed_bonus: p.move_speed_bonus,
                } | rest]
                False -> [p | rest]
            }
            False -> [p | upgrade_player_speed(rest, pid)]
        }
    }
}

